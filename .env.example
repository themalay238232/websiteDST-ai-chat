# Server-side only. Never expose these values in frontend code.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional alternative provider. Use only when OPENAI_API_KEY is empty.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# For GitHub Pages static builds, deploy the chat proxy separately and set
# gh-pages-static/index.html -> window.__DST_CHAT_CONFIG__.apiUrl to that URL.
# Example: https://dst-chat-proxy.your-subdomain.workers.dev/api/chat
